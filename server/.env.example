# ============================================================
# HealthAssist Backend — Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to version control
# ============================================================

# --- Database ---
DATABASE_URL=postgresql+asyncpg://healthassist:healthassist@localhost:5432/healthassist_db

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- LLM (at least one required for AI features) ---
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
LLM_MODEL=gpt-4o
LLM_FALLBACK_MODEL=claude-3-5-sonnet-20241022

# --- External APIs ---
GOOGLE_MAPS_API_KEY=AIza...
GOOGLE_TRANSLATE_API_KEY=AIza...

# --- Security ---
SECRET_KEY=change-me-to-a-32-char-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- App ---
APP_NAME=HealthAssist
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# --- Feature Flags ---
ENABLE_SYNTHETIC_DATA=true
ENABLE_TELEMEDICINE=false
ENABLE_CELERY=false

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=10

# --- SQLite Fallback (for dev without Docker) ---
USE_SQLITE=false
SQLITE_URL=sqlite+aiosqlite:///./healthassist_dev.db
